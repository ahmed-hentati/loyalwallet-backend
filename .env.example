# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loyalwallet
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Apple PassKit (obtenu sur developer.apple.com)
PASS_TYPE_IDENTIFIER=pass.com.yourcompany.loyalwallet
TEAM_IDENTIFIER=YOURTEAMID
APPLE_CERT_PATH=./certs/signerCert.pem
APPLE_KEY_PATH=./certs/signerKey.pem
APPLE_WWDR_PATH=./certs/wwdr.pem
APPLE_KEY_PASSPHRASE=your_certificate_passphrase

# APNs (Push Notifications pour Wallet)
APN_KEY_PATH=./certs/apn_key.p8
APN_KEY_ID=YOUR_KEY_ID
APN_TEAM_ID=YOURTEAMID

# Google Wallet
GOOGLE_APPLICATION_CREDENTIALS=./certs/google-service-account.json
GOOGLE_ISSUER_ID=your_google_issuer_id
